{
  "app_name": "TACNET",
  "version": "1.0.0",
  "creator": "Earl A. Wood, Deputy Sheriff (Ret)",
  "features": {
    "gps_tracking": {
      "refresh_rate": "5s",
      "precision": "high",
      "grid_clearing": "active"
    },
    "emergency_protocols": {
      "sos_trigger": "long_press_header",
      "audio_override": "max_volume",
      "visual_alert": "pulsing_red_shield"
    },
    "k9_modules": {
      "first_aid": "voice_enabled",
      "vet_locator": "auto_gps_radius"
    }
  },
  "security": {
    "access_control": "agency_whitelist",
    "token_expiry": "24h"
  }
}
